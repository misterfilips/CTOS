# NYC Open Data app token — get free at https://data.cityofnewyork.us/profile/edit/developer_settings
# Optional: works without it but may be throttled
VITE_NYC_OPEN_DATA_TOKEN=

# GNews API key — get free at https://gnews.io/ (100 requests/day free)
# Optional: falls back to Google News RSS
VITE_GNEWS_API_KEY=
